# Copy this file to .env and fill in real values. Never commit .env.

# Database (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/content_pilot"

# JWT (auth)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Optional: token lifetime (e.g. 7d, 24h)
JWT_EXPIRES_IN=7d

# Server
PORT=4000
NODE_ENV=development

# File storage (local path for uploads; must exist or be writable)
UPLOAD_DIR=./uploads

# OpenAI (required for market analysis, content plan generation, and post image generation / DALL·E)
# Without this key, market analysis, content plan generation, and POST /api/v1/designs/:projectId/generate will return 503.
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Frontend origin (CORS and callbacks)
FRONTEND_URL=http://localhost:3000
